---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { SITE_TITLE } from '../../consts';

const projects = (await getCollection('projectsZh')).sort(
	(a, b) => a.data.order - b.data.order,
);
const featured = projects.filter((p) => p.data.featured);
const posts = (await getCollection('blogZh'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const focus = ['AI for EHS', '工艺安全', '法规情报', '风险管理'];
const desc =
	'一个长期运营的 EHS × AI 知识实验室——为 EHS 工作的方方面面搭建工具：安全、环保、职业健康、合规。积累作品，而非粉丝。';
---

<!doctype html>
<html lang="zh">
	<head>
		<BaseHead title={`${SITE_TITLE} — EHS × AI`} description={desc} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="container">
					<p class="eyebrow">EHS × AI · 知识实验室</p>
					<h1>Draven EHS Lab</h1>
					<p class="lead">
						一个长期运营的 <strong>EHS</strong> × <strong>AI</strong> 实验室。
						我为 EHS 工作的方方面面搭建工具——安全、环保、职业健康、合规——
						只要 AI 能让这件事更快、更锋利。
					</p>
					<p class="motto">「积累作品，而非粉丝。」</p>
					<div class="actions">
						<a class="btn btn-primary" href="/zh/projects">浏览项目</a>
						<a class="btn" href="/zh/blog">阅读文章</a>
					</div>
					<div class="focus tag-row">
						{focus.map((f) => <span class="tag">{f}</span>)}
					</div>
				</div>
			</section>

			<section class="container">
				<div class="section-head">
					<h2>项目</h2>
					<a class="more-link" href="/zh/projects">全部项目 →</a>
				</div>
				<div class="grid grid-2">
					{featured.map((project) => <ProjectCard project={project} />)}
				</div>
			</section>

			{
				posts.length > 0 && (
					<section class="container">
						<div class="section-head">
							<h2>文章</h2>
							<a class="more-link" href="/zh/blog">
								全部文章 →
							</a>
						</div>
						<ul class="post-list">
							{posts.map((post) => (
								<li>
									<a href={`/zh/blog/${post.id}/`}>
										<span class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</span>
										<span class="post-title">{post.data.title}</span>
										<span class="post-desc muted">{post.data.description}</span>
									</a>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding-block: 5rem 3.5rem;
		border-bottom: 1px solid var(--border-soft);
		background:
			radial-gradient(
				ellipse 60% 50% at 20% -10%,
				rgba(45, 212, 191, 0.1),
				transparent 70%
			);
	}
	.hero h1 {
		font-size: clamp(2.6rem, 7vw, 4.4rem);
		margin: 0 0 1rem;
	}
	.hero .lead {
		max-width: 640px;
		font-size: 1.25rem;
	}
	.motto {
		font-family: var(--font-mono);
		color: var(--accent);
		font-size: 1rem;
		margin: 0.5rem 0 1.8rem;
	}
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-bottom: 2.2rem;
	}
	.focus {
		gap: 0.5rem;
	}
	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 1.6rem;
	}
	.section-head h2 {
		margin: 0;
	}
	.more-link {
		font-family: var(--font-mono);
		font-size: 0.85rem;
	}
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li {
		border-top: 1px solid var(--border);
	}
	.post-list li:last-child {
		border-bottom: 1px solid var(--border);
	}
	.post-list a {
		display: grid;
		grid-template-columns: 160px 1fr;
		gap: 0.4rem 1.5rem;
		padding: 1.3rem 0;
		color: var(--text);
	}
	.post-list a:hover {
		text-decoration: none;
	}
	.post-list a:hover .post-title {
		color: var(--accent);
	}
	.post-date {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		color: var(--text-dim);
		padding-top: 0.15rem;
	}
	.post-title {
		color: var(--heading);
		font-size: 1.2rem;
		font-weight: 700;
		grid-column: 2;
	}
	.post-desc {
		grid-column: 2;
		font-size: 0.95rem;
	}
	@media (max-width: 600px) {
		.post-list a {
			grid-template-columns: 1fr;
			gap: 0.3rem;
		}
		.post-title,
		.post-desc {
			grid-column: 1;
		}
	}
</style>
