---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';

const posts = (await getCollection('blogZh')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh">
	<head>
		<BaseHead
			title="文章 — Draven EHS Lab"
			description="关于 EHS、工艺安全、法规情报，以及为合规工作搭建 AI 工具的原创、务实的文章与研发日志。"
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="container">
				<p class="eyebrow">文章</p>
				<h1>笔记与研发日志</h1>
				<p class="lead">
					关于 EHS 与 AI 的原创、务实的写作——我做了什么、为什么这么做、过程中哪里踩了坑。
					重质量，不追数量。
				</p>
				{
					posts.length === 0 ? (
						<p class="muted">第一篇即将上线。</p>
					) : (
						<ul class="post-list">
							{posts.map((post) => (
								<li>
									<a href={`/zh/blog/${post.id}/`}>
										<span class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</span>
										<span class="post-body">
											<span class="post-title">{post.data.title}</span>
											<span class="post-desc muted">{post.data.description}</span>
											<span class="tag-row">
												{post.data.tags?.map((tg) => (
													<span class="tag">{tg}</span>
												))}
											</span>
										</span>
									</a>
								</li>
							))}
						</ul>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.lead {
		max-width: 640px;
		margin-bottom: 2.5rem;
	}
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li {
		border-top: 1px solid var(--border);
	}
	.post-list li:last-child {
		border-bottom: 1px solid var(--border);
	}
	.post-list a {
		display: grid;
		grid-template-columns: 160px 1fr;
		gap: 1.5rem;
		padding: 1.6rem 0;
		color: var(--text);
	}
	.post-list a:hover {
		text-decoration: none;
	}
	.post-list a:hover .post-title {
		color: var(--accent);
	}
	.post-date {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		color: var(--text-dim);
		padding-top: 0.25rem;
	}
	.post-body {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.post-title {
		color: var(--heading);
		font-size: 1.35rem;
		font-weight: 700;
	}
	.post-desc {
		font-size: 0.98rem;
	}
	@media (max-width: 600px) {
		.post-list a {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}
	}
</style>
