---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const projects = (await getCollection('projects')).sort(
	(a, b) => a.data.order - b.data.order,
);
const featured = projects.filter((p) => p.data.featured);
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const focus = [
	'AI for EHS',
	'Process Safety',
	'Regulatory Intelligence',
	'Risk Management',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — EHS × AI`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<div class="container">
					<p class="eyebrow">EHS × AI · Knowledge Lab</p>
					<h1>Draven EHS Lab</h1>
					<p class="lead">
						A long-term lab at the intersection of <strong>EHS</strong> and
						<strong>AI</strong>. I build tools across the whole span of EHS work —
						safety, environment, occupational health, compliance — wherever AI can
						make the job faster and sharper.
					</p>
					<p class="motto">"Build assets, not followers."</p>
					<div class="actions">
						<a class="btn btn-primary" href="/projects">Explore projects</a>
						<a class="btn" href="/blog">Read the writing</a>
					</div>
					<div class="focus tag-row">
						{focus.map((f) => <span class="tag">{f}</span>)}
					</div>
				</div>
			</section>

			<!-- Featured projects -->
			<section class="container">
				<div class="section-head">
					<h2>Projects</h2>
					<a class="more-link" href="/projects">All projects →</a>
				</div>
				<div class="grid grid-2">
					{featured.map((project) => <ProjectCard project={project} />)}
				</div>
			</section>

			<!-- Latest writing -->
			{
				posts.length > 0 && (
					<section class="container">
						<div class="section-head">
							<h2>Writing</h2>
							<a class="more-link" href="/blog">
								All writing →
							</a>
						</div>
						<ul class="post-list">
							{posts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										<span class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</span>
										<span class="post-title">{post.data.title}</span>
										<span class="post-desc muted">{post.data.description}</span>
									</a>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding-block: 5rem 3.5rem;
		border-bottom: 1px solid var(--border-soft);
		background:
			radial-gradient(
				ellipse 60% 50% at 20% -10%,
				rgba(45, 212, 191, 0.1),
				transparent 70%
			);
	}
	.hero h1 {
		font-size: clamp(2.6rem, 7vw, 4.4rem);
		margin: 0 0 1rem;
	}
	.hero .lead {
		max-width: 640px;
		font-size: 1.25rem;
	}
	.motto {
		font-family: var(--font-mono);
		color: var(--accent);
		font-size: 1rem;
		margin: 0.5rem 0 1.8rem;
	}
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-bottom: 2.2rem;
	}
	.focus {
		gap: 0.5rem;
	}
	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 1.6rem;
	}
	.section-head h2 {
		margin: 0;
	}
	.more-link {
		font-family: var(--font-mono);
		font-size: 0.85rem;
	}
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li {
		border-top: 1px solid var(--border);
		margin: 0;
	}
	.post-list li:last-child {
		border-bottom: 1px solid var(--border);
	}
	.post-list a {
		display: grid;
		grid-template-columns: 160px 1fr;
		gap: 0.4rem 1.5rem;
		padding: 1.3rem 0;
		color: var(--text);
	}
	.post-list a:hover {
		text-decoration: none;
	}
	.post-list a:hover .post-title {
		color: var(--accent);
	}
	.post-date {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		color: var(--text-dim);
		padding-top: 0.15rem;
	}
	.post-title {
		color: var(--heading);
		font-size: 1.2rem;
		font-weight: 700;
		grid-column: 2;
	}
	.post-desc {
		grid-column: 2;
		font-size: 0.95rem;
	}
	@media (max-width: 600px) {
		.post-list a {
			grid-template-columns: 1fr;
			gap: 0.3rem;
		}
		.post-title,
		.post-desc {
			grid-column: 1;
		}
	}
</style>
