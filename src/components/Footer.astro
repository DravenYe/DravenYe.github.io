---
import { SITE_TAGLINE, SOCIAL } from '../consts';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import Social from './Social.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const today = new Date();
---

<footer>
	<div class="container footer-inner">
		<div class="footer-cta">
			<p class="eyebrow">{t('footer.newsletter')}</p>
			<h3>{t('footer.headline')}</h3>
			<p class="muted">{t('footer.blurb')}</p>
			<a class="btn btn-primary" href={SOCIAL.substack} target="_blank" rel="noopener">
				{t('footer.subscribe')}
			</a>
		</div>
		<div class="footer-meta">
			<p class="tagline">{SITE_TAGLINE}</p>
			<Social size={20} />
			<p class="copy muted">
				&copy; {today.getFullYear()} Draven EHS Lab. {t('footer.rights')}
			</p>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		background: var(--bg-elev);
		margin-top: 4rem;
		padding-block: 3rem;
	}
	.footer-inner {
		display: flex;
		flex-wrap: wrap;
		gap: 2.5rem;
		justify-content: space-between;
		align-items: flex-start;
	}
	.footer-cta {
		max-width: 460px;
	}
	.footer-cta h3 {
		margin-bottom: 0.5rem;
	}
	.footer-meta {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: flex-start;
	}
	.tagline {
		font-family: var(--font-mono);
		color: var(--heading);
		margin: 0;
		font-size: 0.95rem;
	}
	.copy {
		font-size: 0.85rem;
		margin: 0;
	}
</style>
